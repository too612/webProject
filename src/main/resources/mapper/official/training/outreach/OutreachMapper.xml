<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.main.app.official.training.outreach.OutreachMapper">

    <select id="selectOutreach" resultType="com.main.app.official.training.outreach.dto.OutreachDto">
        SELECT 1::BIGINT AS id, 'Outreach' AS title, 'Outreach content template' AS content
    </select>

    <insert id="insertOutreach" parameterType="com.main.app.official.training.outreach.dto.OutreachRequest">SELECT 1</insert>
    <update id="updateOutreach">SELECT 1</update>
    <delete id="deleteOutreach">SELECT 1</delete>

</mapper>